# ===========================================
# Visual CMS Production Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# Application
# ===========================================
NODE_ENV=production
LOG_LEVEL=info

# ===========================================
# Ports
# ===========================================
FRONTEND_PORT=80
BACKEND_PORT=5000
PUBLIC_SITE_PORT=3001
PROXY_PORT=8080
PROXY_SSL_PORT=8443

# ===========================================
# API URLs (for frontend build)
# ===========================================
VITE_API_URL=http://localhost:5000/api
VITE_WS_URL=ws://localhost:5000

# ===========================================
# Database (PostgreSQL)
# ===========================================
POSTGRES_USER=cms_user
POSTGRES_PASSWORD=CHANGE_THIS_SECURE_PASSWORD
POSTGRES_DB=visual_cms

# ===========================================
# Redis
# ===========================================
REDIS_URL=redis://redis:6379

# ===========================================
# MinIO (Object Storage)
# ===========================================
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_THIS_SECURE_PASSWORD
S3_BUCKET=cms-media

# ===========================================
# Security
# ===========================================
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARS

# ===========================================
# CORS (comma-separated list)
# ===========================================
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:3000

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# File Upload
# ===========================================
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,image/svg+xml
