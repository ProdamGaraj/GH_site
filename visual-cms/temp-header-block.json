Navigation"},"attributes":{},"layoutMode":"flex","elementType":"container"},{"id":"gh-header-right","styles":{"properties":{"gap":"24px","display":"flex","alignItems":"center"}},"content":"","tagName":"div","children":[{"id":"gh-1771847860006-6","styles":{"states":{"hover":{"color":"#D29F66"}},"properties":{"color":"#FFFFFF","fontSize":"16px","fontFamily":"Muller, sans-serif","fontWeight":"500","textDecoration":"none"},"stateTransition":{"easing":"ease","duration":200,"properties":["color"]}},"content":"+998 78 150-11-11","tagName":"a","children":[],"metadata":{"name":"Phone"},"attributes":{"href":"tel:+998781501111"},"layoutMode":"flex","elementType":"text"},{"id":"gh-1771847860006-7","styles":{"states":{"hover":{"backgroundColor":"#B8864D"}},"properties":{"color":"#FFFFFF","border":"none","cursor":"pointer","padding":"12px 24px","fontSize":"14px","fontFamily":"Muller, sans-serif","fontWeight":"500","borderRadius":"4px","letterSpacing":"1px","textTransform":"uppercase","backgroundColor":"#D29F66"},"stateTransition":{"easing":"ease","duration":200,"properties":["background-color"]}},"content":"Перезвоните мне","tagName":"button","children":[],"metadata":{"name":"CTA Button"},"attributes":{},"layoutMode":"flex","elementType":"button"}],"metadata":{"name":"Header Right"},"attributes":{},"layoutMode":"flex","elementType":"container"},{"id":"gh-header-burger","styles":{"properties":{"gap":"5px","width":"40px","border":"none","cursor":"pointer","height":"40px","zIndex":"1002","display":"none","padding":"8px","position":"relative","alignItems":"center","flexDirection":"column","justifyContent":"center","backgroundColor":"transparent"}},"content":"","scripts":[{"id":"burger-toggle-script","code":"\n        var overlay = document.querySelector('[data-element-id=\"gh-header-overlay\"]');\n        var line1 = document.querySelector('[data-element-id=\"gh-header-burger-l1\"]');\n        var line2 = document.querySelector('[data-element-id=\"gh-header-burger-l2\"]');\n        var line3 = document.querySelector('[data-element-id=\"gh-header-burger-l3\"]');\n        var isOpen = false;\n\n        element.addEventListener('click', function(e) {\n          e.stopPropagation();\n          isOpen = !isOpen;\n          element.setAttribute('aria-expanded', isOpen ? 'true' : 'false');\n\n          if (isOpen) {\n            // Анимация бургера → крестик\n            line1.style.transform = 'translateY(7px) rotate(45deg)';\n            line2.style.opacity = '0';\n            line3.style.transform = 'translateY(-7px) rotate(-45deg)';\n            // Показать оверлей\n            overlay.style.visibility = 'visible';\n            overlay.style.opacity = '1';\n            // Заблокировать скролл\n            document.body.style.overflow = 'hidden';\n          } else {\n            // Анимация крестик → бургер\n            line1.style.transform = 'none';\n            line2.style.opacity = '1';\n            line3.style.transform = 'none';\n            // Скрыть оверлей\n            overlay.style.opacity = '0';\n            setTimeout(function() { overlay.style.visibility = 'hidden'; }, 300);\n            // Вернуть скролл\n            document.body.style.overflow = '';\n          }\n        });\n\n        // Закрытие при клике на ссылку в оверлее\n        if (overlay) {\n          overlay.querySelectorAll('a').forEach(function(link) {\n            link.addEventListener('click', function() {\n              isOpen = false;\n              element.setAttribute('aria-expanded', 'false');\n              line1.style.transform = 'none';\n              line2.style.opacity = '1';\n              line3.style.transform = 'none';\n              overlay.style.opacity = '0';\n              setTimeout(function() { overlay.style.visibility = 'hidden'; }, 300);\n              document.body.style.overflow = '';\n            });\n          });\n        }\n      ","name":"Burger Menu Toggle","enabled":true,"trigger":"load"}],"tagName":"button","children":[{"id":"gh-header-b